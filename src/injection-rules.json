{
  "chatgpt": {
    "selectors": {
      "input": "#prompt-textarea",
      "inputAlt": "div[contenteditable=\"true\"]",
      "sendBtn": "[data-testid=\"send-button\"]",
      "sendBtnAlt": "button[data-testid=\"send-button\"]",
      "stopBtn": "[data-testid=\"stop-button\"]"
    },
    "inputType": "contenteditable",
    "injectionMethod": "contenteditable",
    "requiresLogin": true,
    "notes": "ChatGPT ha cambiato da textarea a contenteditable div. Usa typing simulato."
  },
  "claude": {
    "selectors": {
      "input": "div[contenteditable=\"true\"][data-testid=\"chat-input\"]",
      "inputAlt": "div[contenteditable=\"true\"]",
      "sendBtn": "button[aria-label=\"Send message\"]",
      "sendBtnAlt": "[data-testid=\"model-selector-dropdown\"] ~ div button"
    },
    "inputType": "contenteditable",
    "injectionMethod": "contenteditable",
    "requiresLogin": true,
    "notes": "Claude usa contenteditable. SendBtnAlt usa la posizione relativa al model selector per essere language-agnostic."
  },
  "gemini": {
    "selectors": {
      "input": "div.ql-editor[contenteditable=\"true\"]",
      "inputAlt": "div[role=\"textbox\"][contenteditable=\"true\"]",
      "sendBtn": "button:has(mat-icon[data-mat-icon-name=\"send\"])",
      "sendBtnAlt": "button.send-button"
    },
    "inputType": "contenteditable",
    "injectionMethod": "contenteditable",
    "requiresLogin": true,
    "notes": "Gemini usa Quill editor. SendBtn usa icona o classe specifica per essere language-agnostic."
  },
  "perplexity": {
    "selectors": {
      "input": "div[contenteditable=\"true\"]#ask-input",
      "sendBtn": "button[aria-label=\"Submit\"]",
      "sendBtnAlt": "button:has(svg[data-icon=\"arrow-right\"]), button:has(use[xlink\\:href*=\"arrow-right\"])"
    },
    "inputType": "contenteditable",
    "injectionMethod": "contenteditable",
    "requiresLogin": false,
    "notes": "Perplexity funziona anche senza login. SendBtn usa aria-label o icona arrow-right."
  },
  "copilot": {
